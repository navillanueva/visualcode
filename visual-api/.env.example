# ──────────────────────────────────────────────────────────────────────────
# Visual Code API (Plan 3 — the backend hub). Copy to .env and fill REAL values.
# Var names mirror the repo root .env.example (Arc / Unlink / Gateway / Dynamic).
# .env is gitignored — never commit secrets.
# ──────────────────────────────────────────────────────────────────────────

# ── Service ────────────────────────────────────────────────────────────────
PORT=8787
# Public base URL of THIS service (Railway gives you one). The TUI + web read it
# as VISUALCODE_API_URL; kept here for self-reference / smoke output.
VISUALCODE_API_URL=http://localhost:8787
# Comma-separated allowed browser origins for the web app (CORS w/ credentials).
# Leave empty in local dev to reflect the request origin.
CORS_ORIGIN=

# ── Postgres (Railway Postgres gives you DATABASE_URL) ───────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/visualcode

# ── Auth ─────────────────────────────────────────────────────────────────────
# HMAC secret for signed session cookies + at-rest encryption of imported keys.
# Generate: `openssl rand -hex 32`. REQUIRED.
TOKEN_SIGNING_SECRET=

# Dynamic (app.dynamic.xyz → Developer tab). Used to verify the Dynamic JWT on
# POST /api/auth/dynamic (signature via the env's JWKS; server key gates the call).
DYNAMIC_ENVIRONMENT_ID=
DYNAMIC_SERVER_API_KEY=

# ── World ID personhood gate (developer.worldcoin.org → your app) ────────────
# Binds a World ID nullifier to an account (one human = one account) and gates
# payout + campaign creation. Leave WORLD_ID_APP_ID empty to disable: the
# verify-human endpoint returns 503 and the gates become no-ops (mock/dev).
# WORLD_ID_APP_ID + WORLD_ID_ACTION are created in the World Developer Portal.
WORLD_ID_APP_ID=
# Shared action — one action ⇒ a human can bind exactly one account total.
WORLD_ID_ACTION=visualcode-account
# Optional: override the cloud verify base URL (the 4.0 ⟷ classic endpoint swap).
WORLD_ID_VERIFY_URL=

# Public base URL of the web app — surfaced in earnings so the TUI can link the
# developer to the "verify your humanity to get paid" page.
WEB_APP_URL=

# ── Settlement provider selection ────────────────────────────────────────────
# "mock" (default — no chain, deterministic) or "real" (gated live Arc path).
# Real requires the vendor SDKs (@unlink-xyz/sdk is NOT on the public npm
# registry — install it from your private/Arc source) + the secrets below.
SETTLEMENT_MODE=mock

# ── Arc testnet (only needed when SETTLEMENT_MODE=real) ──────────────────────
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
# Server-side payer EOA (funds Circle Gateway x402). Keep USDC on it (USDC = gas).
PAYER_ADDRESS=
PAYER_PRIVATE_KEY=

# ── Unlink (privacy) — real path only ────────────────────────────────────────
UNLINK_ENVIRONMENT=arc-testnet
UNLINK_API_KEY=
# Escape hatch: required because "arc-testnet" is not a built-in SDK env.
UNLINK_ENGINE_URL=https://arc-testnet-production-api.unlink.xyz
# BIP-39 seed for the backend's private Unlink account (server-side signer).
UNLINK_MNEMONIC=

# ── Live smoke gate (the single allowed on-chain test) ───────────────────────
# KICKBACK_SMOKE_CONFIRM=1
