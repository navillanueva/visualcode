# Visual Code Web — frontend env. Copy to `.env` (or `.env.local`) for local dev.
# Only NEXT_PUBLIC_* vars are read here; they ship to the browser, so keep them public-safe.
# The DYNAMIC_SERVER_API_KEY lives in the BACKEND (visual-api), NEVER in this app.

# Dynamic SDK environment id (public). From app.dynamic.xyz -> Developer -> SDK & API Keys.
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=7414ec5a-966e-4219-8b8a-2fe843f38ff2

# Base URL of the visual-api backend (Plan 3). Railway provides this in prod.
NEXT_PUBLIC_VISUALCODE_API_URL=http://localhost:8787

# World ID personhood gate (public). Create the app + action in the World
# Developer Portal (developer.worldcoin.org). The app_id starts with `app_`;
# the action must match WORLD_ID_ACTION in the visual-api backend. If unset, the
# VerifyHuman widget renders a disabled note instead of crashing.
NEXT_PUBLIC_WORLD_ID_APP_ID=
NEXT_PUBLIC_WORLD_ID_ACTION=visualcode-account
